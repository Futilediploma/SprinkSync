# Development Environment Variables Example
# Copy to .env and update with your development values

# Security - Generate new ones for each environment
SECRET_KEY=development-secret-key-change-for-production
JWT_SECRET_KEY=development-jwt-secret-change-for-production

# Environment
ENVIRONMENT=development
DEBUG=true

# Database - SQLite for development, PostgreSQL for production
DATABASE_URL=sqlite:///./sprinksync.db

# CORS - Development origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration (for user invitations)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# File Upload Security
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx,txt
UPLOAD_DIRECTORY=./uploads

# Optional: OpenAI API for Document Processing
OPENAI_API_KEY=your_openai_api_key_here
